###1、fnm安装方式
curl -fsSLk https://gh-proxy.org/https://github.com/Schniz/fnm/releases/download/v1.39.0/fnm-linux.zip -o fnm.zip --verbose
apt install -y unzip
unzip -o fnm.zip 
sudo mv fnm /usr/local/bin/
rm fnm.zip
###fnm--更改fnm镜像源地址：linux
echo 'export FNM_NODE_DIST_MIRROR=https://mirrors.aliyun.com/nodejs-release/' >> ~/.bashrc && source ~/.bashrc
###苹果MACOS--zsh
echo 'export FNM_NODE_DIST_MIRROR=https://mirrors.aliyun.com/nodejs-release/' >> ~/.zshrc && source ~/.zshrc
###安装
fnm install 24
cp /root/.local/share/fnm/node-versions/v24.14.1/installation/bin/node /usr/local/bin

###2、n安装方式
curl -fsSL https://gh-proxy.org/https://raw.githubusercontent.com/mklement0/n-install/stable/bin/n-install | bash -s 24
###linux设置n的加速地址
echo 'export N_NODE_MIRROR=https://npmmirror.com/mirrors/node' >> ~/.bashrc
###苹果MACOS--zsh
echo 'export N_NODE_MIRROR=https://npmmirror.com/mirrors/node' >> ~/.zshrc
source ~/.bashrc  # 立即生效
###手动安装
cp ~/n/bin/n /usr/local/bin
n install 24
cp /root/n/n/versions/node/24.14.1/bin/node /usr/local/bin/

###3、nvm安装方式
curl -o- https://gh-proxy.proxy.org/https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
\. "$HOME/.nvm/nvm.sh"
echo 'export NVM_NODEJS_ORG_MIRROR=https://mirrors.aliyun.com/nodejs-release/' >> ~/.bashrc
source ~/.bashrc
nvm install 24
cp /root/.nvm/versions/node/v24.1.0/bin/node /usr/local/bin
nvm deactivate
nvm uninstall v24.1.0

