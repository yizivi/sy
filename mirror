###scoop
powershell -executionpolicy bypass -command "iwr https://gh-proxy.org/raw.githubusercontent.com/ScoopInstaller/Install/master/install.ps1 | iex"
[environment]::setEnvironmentVariable('PATH',"$env:USERPROFILE\scoop\shims;" + $env:PATH,'USER')

# 替换 Scoop 源为 Gitee（国内）
scoop config SCOOP_REPO https://gitee.com/ScoopInstaller/Scoop
scoop bucket add main https://gitee.com/ScoopInstaller/Main

# 启用 Aria2 多线程下载（加速）
scoop install aria2

# 添加常用仓库（开发工具）
scoop bucket add extras
scoop bucket add versions
scoop bucket add nerd-fonts

# 自定义安装路径（可选，比如 D 盘）
scoop config root D:\scoop
scoop config global_path D:\scoop\apps

